-- 4. Create Historical Receivables (For Cortex ML Training)
-- We need historical data showing which invoices were paid late to train the model.
CREATE OR REPLACE TABLE receivables_history (
    invoice_id VARCHAR,
    client_id VARCHAR,
    invoice_amount FLOAT,
    days_to_pay INT,
    past_dso_avg INT, -- Client's historical average days to pay
    is_late BOOLEAN   -- TARGET VARIABLE for ML (True if paid past 30 days)
);

