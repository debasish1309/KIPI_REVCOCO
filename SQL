-- 5.Expand contracts to 50 clients (reference table)
INSERT INTO contracts
SELECT
    'C' || LPAD(ROW_NUMBER() OVER (ORDER BY SEQ4()), 3, '0')        AS client_id,
    CASE FLOOR(UNIFORM(1, 6, RANDOM()))
        WHEN 1 THEN 'Pinnacle Solutions'
        WHEN 2 THEN 'Bright Media'
        WHEN 3 THEN 'Sterling Logistics'
        WHEN 4 THEN 'Nexus Retail'
        WHEN 5 THEN 'Summit Finance'
    END || ' ' || ROW_NUMBER() OVER (ORDER BY SEQ4())                AS client_name,
    ROUND(UNIFORM(0.10, 0.20, RANDOM()), 2)                         AS print_rate,
    ROUND(UNIFORM(0.03, 0.08, RANDOM()), 3)                         AS digital_rate,
    DATEADD(day, -FLOOR(UNIFORM(30, 730, RANDOM())), CURRENT_DATE()) AS contract_start_date
FROM TABLE(GENERATOR(ROWCOUNT => 47)); -- 47 new + 3 existing = 50 total


-- 6.Generate 1,000,000 rows for production_logs
INSERT INTO production_logs (client_id, event_type, quantity, event_timestamp)
SELECT
    -- Assign to one of 50 clients, weighted so C001-C010 are busier
    'C' || LPAD(
        CASE
            WHEN UNIFORM(0.0, 1.0, RANDOM()) < 0.40  -- 40% go to top 10 clients
            THEN FLOOR(UNIFORM(1, 10, RANDOM()))
            ELSE FLOOR(UNIFORM(1, 50, RANDOM()))
        END,
        3, '0'
    )                                                               AS client_id,

    -- PRINT is ~60%, DIGITAL is ~40%
    CASE WHEN UNIFORM(0.0, 1.0, RANDOM()) < 0.60
        THEN 'PRINT' ELSE 'DIGITAL'
    END                                                             AS event_type,

    -- PRINT: lower qty (1k–50k), DIGITAL: higher qty (10k–500k)
    CASE WHEN UNIFORM(0.0, 1.0, RANDOM()) < 0.60
        THEN FLOOR(UNIFORM(1000,  50000,  RANDOM()))
        ELSE FLOOR(UNIFORM(10000, 500000, RANDOM()))
    END                                                             AS quantity,

    -- Spread events across the last 2 years
    DATEADD(
        second,
        -FLOOR(UNIFORM(0, 63072000, RANDOM())), -- 63072000s = 2 years
        CURRENT_TIMESTAMP()
    )                                                               AS event_timestamp

FROM TABLE(GENERATOR(ROWCOUNT => 1000000));

-- 7. Generate 1,000,000 rows for receivables_history
INSERT INTO receivables_history
WITH base AS (
    SELECT
        SEQ4() + 200                                                AS seq_num, -- offset past existing INV-1xx

        -- Client bucketing: 20% "risky" clients (like C003), 80% normal
        CASE
            WHEN UNIFORM(0.0, 1.0, RANDOM()) < 0.20
            THEN 'C' || LPAD(FLOOR(UNIFORM(30, 50, RANDOM())), 3, '0') -- risky band
            ELSE 'C' || LPAD(FLOOR(UNIFORM(1,  29, RANDOM())), 3, '0') -- normal band
        END                                                         AS client_id,

        -- Invoice amount: skewed, most are small, some are large
        ROUND(
            CASE WHEN UNIFORM(0.0, 1.0, RANDOM()) < 0.70
                THEN UNIFORM(500.0,  5000.0,  RANDOM())
                ELSE UNIFORM(5000.0, 50000.0, RANDOM())
            END,
            2
        )                                                           AS invoice_amount,

        -- past_dso_avg: risky clients average 35-55, normal 10-30
        CASE
            WHEN UNIFORM(0.0, 1.0, RANDOM()) < 0.20
            THEN FLOOR(UNIFORM(35, 55, RANDOM()))
            ELSE FLOOR(UNIFORM(10, 30, RANDOM()))
        END                                                         AS past_dso_avg

    FROM TABLE(GENERATOR(ROWCOUNT => 1000000))
),
with_payment AS (
    SELECT
        seq_num,
        client_id,
        invoice_amount,
        past_dso_avg,

        -- days_to_pay: anchored around past_dso_avg with variance
        -- Large invoices add 0-15 extra days
        GREATEST(1, FLOOR(
            past_dso_avg
            + UNIFORM(-10, 20, RANDOM())                            -- natural variance
            + CASE WHEN invoice_amount > 10000 THEN FLOOR(UNIFORM(0, 15, RANDOM())) ELSE 0 END
        ))                                                          AS days_to_pay

    FROM base
)
SELECT
    'INV-' || LPAD(seq_num, 6, '0')                                AS invoice_id,
    client_id,
    invoice_amount,
    days_to_pay,
    past_dso_avg,
    (days_to_pay > 30)                                              AS is_late
FROM with_payment;

-- 8.Verification Queries
-- Row counts
SELECT 'contracts'          AS tbl, COUNT(*) AS "rows" FROM contracts
UNION ALL
SELECT 'production_logs',              COUNT(*) FROM production_logs
UNION ALL
SELECT 'receivables_history',          COUNT(*) FROM receivables_history;

-- Check ML signal: is_late rate should be ~30-40%
SELECT
    is_late,
    COUNT(*)                          AS count,
    ROUND(AVG(invoice_amount), 2)     AS avg_amount,
    ROUND(AVG(past_dso_avg), 1)       AS avg_dso
FROM receivables_history
GROUP BY is_late;

-- Production log event distribution
SELECT
    event_type,
    COUNT(*)                          AS events,
    ROUND(AVG(quantity), 0)           AS avg_qty,
    MIN(event_timestamp)              AS earliest,
    MAX(event_timestamp)              AS latest
FROM production_logs
GROUP BY event_type;

